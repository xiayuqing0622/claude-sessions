#!/usr/bin/env python3
"""cs-hook - Auto-label Claude session on first tool use.

Called by Claude Code's PreToolUse hook. Reads the session's first
user message from history.jsonl and saves it as the session label.
Only runs once per session (skips if label already exists).
"""
import json
import os
import sys
import urllib.request
import urllib.error
from pathlib import Path

LABELS_FILE = Path.home() / ".claude" / "session-labels.json"
HISTORY_FILE = Path.home() / ".claude" / "history.jsonl"
CREDS_FILE = Path.home() / ".claude" / ".credentials.json"
MAX_LABEL_LEN = 30


def get_session_id():
    """Find session_id by walking up process tree to find claude, then matching in history."""
    # Walk up to find the parent claude process
    ppid = os.getppid()
    claude_pid = None
    while ppid > 1:
        try:
            comm = Path(f"/proc/{ppid}/comm").read_text().strip()
        except OSError:
            break
        if comm == "claude":
            claude_pid = ppid
            break
        try:
            stat = Path(f"/proc/{ppid}/stat").read_text()
            ppid = int(stat.split()[3])
        except (OSError, IndexError, ValueError):
            break

    if not claude_pid:
        return None, None

    # Get claude's cwd and start time
    try:
        cwd = os.readlink(f"/proc/{claude_pid}/cwd")
        stat_time = os.stat(f"/proc/{claude_pid}").st_mtime
    except OSError:
        return None, None

    # Find matching session in history
    if not HISTORY_FILE.exists():
        return None, None

    sessions = {}
    with open(HISTORY_FILE, "r") as f:
        for line in f:
            try:
                msg = json.loads(line.strip())
            except Exception:
                continue
            if msg.get("project", "") != cwd:
                continue
            sid = msg.get("sessionId", "")
            ts = msg.get("timestamp", 0) / 1000
            if sid not in sessions:
                sessions[sid] = {"first_ts": ts, "last_ts": ts, "display": msg.get("display", "")}
            else:
                sessions[sid]["last_ts"] = ts

    # Among sessions starting within 300s of process start, pick most recently active
    candidates = []
    for sid, info in sessions.items():
        if info["first_ts"] >= stat_time - 60:
            candidates.append((-info["last_ts"], sid, info["display"]))
    candidates.sort()

    if candidates:
        return candidates[0][1], candidates[0][2]
    return None, None


def get_oauth_token():
    """Read OAuth token from credentials file."""
    if not CREDS_FILE.exists():
        return None
    try:
        creds = json.loads(CREDS_FILE.read_text())
        return creds.get("claudeAiOauth", {}).get("accessToken")
    except Exception:
        return None


def summarize_label(text, token):
    """Call Haiku to summarize a long message into a short label."""
    req = urllib.request.Request(
        "https://api.anthropic.com/v1/messages",
        data=json.dumps({
            "model": "claude-haiku-4-5-20251001",
            "max_tokens": 40,
            "messages": [{"role": "user", "content":
                f"Summarize this task into a very short label (max {MAX_LABEL_LEN} chars, same language as input). "
                f"Output ONLY the label, nothing else.\n\n{text}"}],
        }).encode(),
        headers={
            "Content-Type": "application/json",
            "Authorization": f"Bearer {token}",
            "anthropic-version": "2023-06-01",
            "anthropic-beta": "oauth-2025-04-20",
        },
    )
    try:
        with urllib.request.urlopen(req, timeout=5) as resp:
            body = json.loads(resp.read())
            label = body["content"][0]["text"].strip().strip('"')
            return label[:MAX_LABEL_LEN] if len(label) > MAX_LABEL_LEN else label
    except Exception:
        return None


def make_label(first_message):
    """Make a short label: summarize via Haiku if long, otherwise truncate."""
    text = first_message.split("\n")[0]
    if len(text) <= MAX_LABEL_LEN:
        return text

    token = get_oauth_token()
    if token:
        summary = summarize_label(text, token)
        if summary:
            return summary

    # Fallback: simple truncation
    return text[:MAX_LABEL_LEN - 3] + "..."


def main():
    session_id, first_message = get_session_id()
    if not session_id or not first_message:
        return

    # Load existing labels
    labels = {}
    if LABELS_FILE.exists():
        try:
            labels = json.loads(LABELS_FILE.read_text())
        except Exception:
            pass

    # Skip if already labeled
    if session_id in labels:
        return

    labels[session_id] = make_label(first_message)
    LABELS_FILE.write_text(json.dumps(labels, indent=2, ensure_ascii=False))


if __name__ == "__main__":
    main()
